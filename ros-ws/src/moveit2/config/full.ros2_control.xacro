<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="full_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${xacro.load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <!-- By default, set up controllers for simulation. This won't work on real hardware -->
                <plugin>mock_components/GenericSystem</plugin>
            </hardware>
            <joint name="jrotate1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jrotate1']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jlink1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jlink1']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jlink2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jlink2']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jrotate2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jrotate2']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jend">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jend']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jsgear">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jsgear']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="jhorn">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['jhorn']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>


            <!-- ── PASSIVE JOINTS (spring-activated, state-only, no command interface) ──
                 jconnector, jbutton1, jbutton2 = connector 1 mechanism (gripper)
                 jmconnector, jmbutton1, jmbutton2 = connector 2 mechanism (magnet)
                 These are NOT commanded — springs move them physically.
                 We register state_interfaces so joint_state_broadcaster can publish
                 their positions and MoveIt2 won't complain about unknown joint states. -->
            <joint name="jconnector">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
            <joint name="jbutton1">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
            <joint name="jbutton2">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
            <joint name="jmconnector">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
            <joint name="jmbutton1">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
            <joint name="jmbutton2">
                <state_interface name="position">
                    <param name="initial_value">0</param>
                </state_interface>
            </joint>
        </ros2_control>
    </xacro:macro>
</robot>